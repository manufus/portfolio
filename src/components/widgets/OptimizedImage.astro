---
/**
 * OptimizedImage component is a modified version of Astro's built-in Image component.
 * It allows to optimize images inside public, src/assets and content folders.
 * To optimize remote images, follow: https://docs.astro.build/en/guides/images/#authorizing-remote-images
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type ExtraAttributeValue = string | number | boolean | null | undefined;

export interface Props {
  src: string;
  alt?: string;
  inlineSvg?: boolean;
  width?: number;
  height?: number;
  loading?: "eager" | "lazy";
  decoding?: "async" | "auto" | "sync";
  formats?: string[] | "auto" | "avif" | "jpeg" | "png" | "svg" | "webp";
  class?: string;
  style?: string;
  [key: string]: ExtraAttributeValue | string[] | undefined;
}

// Destructuring Astro.props to get the component's props
const {
  src,
  alt,
  inlineSvg = false,
  width,
  height,
  loading,
  decoding,
  formats: _formats,
  style,
  class: className,
  ...rest
} = Astro.props as Props;

const isRemoteImage = src.startsWith("http://") || src.startsWith("https://");
let image: string | ImageMetadata | null = src;
let svgMarkup = "";

if (!isRemoteImage) {
  // Regular Images
  const images = import.meta.glob<{ default: ImageMetadata }>([
    "/src/assets/**/*.{jpeg,jpg,png,avif,tiff,gif,webp,svg,gif}",
    "/public/**/*.{jpeg,jpg,png,avif,tiff,gif,webp,svg,gif}",
    "/src/content/**/*.{jpeg,jpg,png,avif,tiff,gif,webp,svg,gif}",
  ]);

  // Get Raw Image For Inline SVG
  const imagesRaw = import.meta.glob<string>(
    ["/src/assets/**/*.svg", "/src/content/**/*.svg", "/public/**/*.svg"],
    {
      query: "raw",
      import: "default",
    },
  );

  if (inlineSvg && src.includes(".svg")) {
    const key = Object.keys(images).find((k) => k.includes(src));
    const rawLoader = key ? imagesRaw[key] : undefined;
    svgMarkup = rawLoader ? await rawLoader() : "";

    if (svgMarkup.length > 1) {
      const svgParts = svgMarkup.split("<svg"); // Split at the opening <svg> tag

      if (svgParts.length > 1) {
        // Convert rest object to a string of attributes
        const attributes = Object.entries(rest)
          .map(([key, value]) => `${key}="${String(value)}"`)
          .join(" ");

        // Add the attributes to the <svg> tag
        svgParts[1] = ` data-icon="true" ${attributes} ${svgParts[1]}`;
      }

      // Join the array back into a string
      svgMarkup = svgParts.join("<svg");
    }
  }

  const key = Object.keys(images).find((k) => k.includes(src));
  const imageLoader = key ? images[key] : undefined;
  const loadedImage = imageLoader ? await imageLoader() : null;
  image = loadedImage?.default ?? null;
}

const remoteImage = typeof image === "string" ? image : null;
const localImage = image && typeof image !== "string" ? image : null;
---

{
  inlineSvg && svgMarkup && src.includes(".svg") ? (
    <Fragment set:html={svgMarkup} />
  ) : remoteImage ? (
    <Image
      src={remoteImage}
      alt={alt || ""}
      width={width ?? 1200}
      height={height ?? 630}
      inferSize
      {...(style !== undefined ? { style } : {})}
      {...(loading !== undefined ? { loading } : {})}
      {...(decoding !== undefined ? { decoding } : {})}
      {...(className !== undefined ? { class: className } : {})}
      {...rest}
    />
  ) : localImage ? (
    <Image
      src={localImage}
      alt={alt || ""}
      {...(style !== undefined ? { style } : {})}
      {...(loading !== undefined ? { loading } : {})}
      {...(decoding !== undefined ? { decoding } : {})}
      {...(className !== undefined ? { class: className } : {})}
      {...rest}
    />
  ) : null
}
