---
import { Icon } from "astro-icon/components";

export interface Props {
  className?: string;
  primaryAction?: {
    label: string;
    url: string;
  };
  secondaryActions?: Array<{
    icon: string;
    url: string;
    ariaLabel: string;
  }>;
}

const {
  className = "",
  primaryAction = {
    label: "Visit Site",
    url: "#",
  },
  secondaryActions = [],
} = Astro.props as Props;

const secondaryBtnClass =
  "inline-flex items-center justify-center h-10 w-10 rounded-xl bg-neutral-800/80 ring-1 ring-white/10 text-neutral-200 hover:text-white hover:bg-neutral-700/80 transition-colors";
---

<div
  class={`fixed z-60 bottom-5 left-1/2 -translate-x-1/2 sm:bottom-6 md:bottom-8 ${className}`}
  data-aos="fade-up-sm"
  data-aos-delay="200"
  data-aos-duration="500"
  data-aos-once="true"
>
  <div
    class="flex items-center gap-1 sm:gap-2 rounded-2xl bg-neutral-900/85 dark:bg-neutral-900/85 text-neutral-100 shadow-[0_6px_28px_rgba(0,0,0,0.25)] ring-1 ring-white/10 backdrop-blur-xl px-2 py-2 max-w-[92vw]"
  >
    {
      secondaryActions.length > 0 && (
        <div
          class="flex items-center gap-1 sm:gap-1 overflow-x-auto scrollbar-none max-w-[55vw] sm:max-w-[62vw] md:max-w-[70vw] pr-1"
        >
          {secondaryActions.map((action) => (
            <a
              href={action.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={action.ariaLabel}
              class={secondaryBtnClass}
            >
              <Icon name={action.icon} class="size-5 opacity-90" aria-hidden="true" />
            </a>
          ))}
        </div>
      )
    }

    <div class="shrink-0">
      <a
        href={primaryAction.url}
        target="_blank"
        rel="nofollow noopener"
        class="inline-flex items-center h-10 sm:h-11 px-4 sm:px-5 rounded-xl bg-yellow-300 text-neutral-900 text-sm hover:bg-yellow-200 transition-colors whitespace-nowrap"
      >
        {primaryAction.label}
      </a>
    </div>
  </div>
</div>
