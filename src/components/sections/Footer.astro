---
import Logo from "@/components/ui/Logo.astro";
import ToTop from "@/components/widgets/ToTop.astro";
import { siteConfig, socialLinks } from "@/config/site.js";
---

<section
  class="text-content-secondary border-t mt-6 md:mt-6 border-dashed border-border-subtle border-[.75px]"
>
  <div
    class="container flex flex-col items-center py-8 mx-auto px-7 max-w-7xl sm:flex-row"
  >
    <Logo />
    <p
      class="mt-4 text-sm text-content-tertiary sm:ml-4 sm:pl-4 sm:border-l sm:border-border-subtle sm:mt-0"
    >
      © {new Date().getFullYear()}

      <a
        href={siteConfig.url || " "}
        
        class="hover:text-primary transition-colors"
        >{siteConfig.author || " "}</a
      >
      <span class="hidden sm:inline">&nbsp|</span>
      <span class="pl-1">
        <a
          href="/privacy"
          
          class="hover:text-primary transition-colors"
          title="GDPR Compliance"
        >
          Privacy Policy
        </a>
        &nbsp;|&nbsp;
        <a
          href="/license"
          
          class="hover:text-primary transition-colors"
          title="Apache License 2.0"
        >
          Legal Notice
        </a>
      </span>
    </p>
    <span
      class="inline-flex justify-center mt-4 space-x-5 sm:ml-auto sm:mt-0 sm:justify-start overflow-hidden"
    >
      {
        socialLinks.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-icon-link text-content-secondary "
            title={social.name}
          >
            <span class="sr-only">{social.name}</span>
            <div class="footer-social-icon text-content-secondary">
              <Fragment set:html={social.icon} />
            </div>
          </a>
        ))
      }
    </span>
  </div>
</section>

<ToTop />

<style is:global>
  .footer-social-icon {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease-in-out;
    overflow: hidden;
  }

  .footer-social-icon svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
    transition: all 0.3s ease-in-out;
  }
  .footer-social-icon-link:hover .footer-social-icon svg {
    width: auto;
    height: 24px;
    fill: currentColor;
  }

  .footer-social-icon-link:hover .ic-twitter,
  .footer-social-icon-link:hover .ic-github,
  .footer-social-icon-link:hover .ic-zcool,
  .footer-social-icon-link:hover .ic-behance,
  .footer-social-icon-link:hover .ic-rss {
    color: var(--color-brand);
  }
</style>
