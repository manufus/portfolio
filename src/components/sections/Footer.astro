---
import ToTop from "@/components/features/ToTop.astro";
import {
  COOKIE_CONSENT_RESET_EVENT,
  COOKIE_CONSENT_STORAGE_KEY,
} from "@/components/islands/CookieConsent/constants";
import Logo from "@/components/primitives/Logo.astro";
import { siteConfig, socialLinks } from "@/config/site";
---

<section
  class="text-content-secondary border-t mt-6 md:mt-6 border-dashed border-border-subtle border-[.75px]"
>
  <div
    class="container flex flex-col items-center py-8 mx-auto px-7 max-w-7xl sm:flex-row"
  >
    <Logo />
    <p
      class="mt-4 text-sm text-content-tertiary sm:ml-4 sm:pl-4 sm:border-l sm:border-border-subtle sm:mt-0"
    >
      © {new Date().getFullYear()}

      <a
        href={siteConfig.url || " "}
        
        class="hover:text-primary transition-colors"
        >{siteConfig.author || " "}</a
      >
      <span class="hidden sm:inline">&nbsp|</span>
      <span class="pl-1">
        <a
          href="/privacy"
          
          class="hover:text-primary transition-colors"
          title="GDPR Compliance"
        >
          Privacy Policy
        </a>
        &nbsp;|&nbsp;
        <a
          href="/privacy#cookie-preferences"
          data-cookie-consent-manage
          class="hover:text-primary transition-colors"
          title="Manage cookie preferences"
        >
          Reset Cookies
        </a>
        &nbsp;|&nbsp;
        <a
          href="/license"
          
          class="hover:text-primary transition-colors"
          title="Apache License 2.0"
        >
          Legal Notice
        </a>
      </span>
    </p>
    <span
      class="inline-flex justify-center mt-4 space-x-5 sm:ml-auto sm:mt-0 sm:justify-start overflow-hidden"
    >
      {
        socialLinks.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-icon-link text-content-secondary "
            title={social.name}
          >
            <span class="sr-only">{social.name}</span>
            <div class="footer-social-icon text-content-secondary">
              <Fragment set:html={social.icon} />
            </div>
          </a>
        ))
      }
    </span>
  </div>
</section>

<ToTop />

<script is:inline define:vars={{ COOKIE_CONSENT_STORAGE_KEY, COOKIE_CONSENT_RESET_EVENT }}>
  (() => {
    const trigger = document.querySelector("[data-cookie-consent-manage]");
    if (!trigger) return;

    trigger.addEventListener("click", (event) => {
      event.preventDefault();

      try {
        window.localStorage.removeItem(COOKIE_CONSENT_STORAGE_KEY);
      } catch {
        // Ignore restricted localStorage environments.
      }

      window.dispatchEvent(new CustomEvent(COOKIE_CONSENT_RESET_EVENT));
      window.dispatchEvent(
        new CustomEvent("ds:toast", {
          detail: {
            title: "Cookie preferences reset",
            message: "Please choose your cookie preferences again.",
            variant: "info",
          },
        }),
      );
    });
  })();
</script>

<style is:global>
  .footer-social-icon {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease-in-out;
    overflow: hidden;
  }
  
  .footer-social-icon-link:hover .ic-twitter,
  .footer-social-icon-link:hover .ic-github,
  .footer-social-icon-link:hover .ic-zcool,
  .footer-social-icon-link:hover .ic-behance,
  .footer-social-icon-link:hover .ic-rss {
    color: var(--color-brand);
  }
</style>
