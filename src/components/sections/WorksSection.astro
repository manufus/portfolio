---
import type { ImageMetadata } from "astro";
import works from "@/collections/works.json";
import WorkCard from "@/components/composites/WorkCard.astro";

export interface Props {
  limit?: number; // Limit the number of visible projects
}

interface Work {
  name: string;
  description?: string;
  image: ImageMetadata;
  url: string;
  tags?: string[];
  isShow?: boolean;
}

interface RawWork extends Omit<Work, "image"> {
  image: string;
}

const projectImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);

const resolveProjectImage = (imageFileName: string): ImageMetadata => {
  if (!imageFileName) {
    throw new Error("Invalid project image filename.");
  }

  const assetModule = projectImages[`/src/assets/projects/${imageFileName}`];

  if (!assetModule) {
    throw new Error(`Missing project image file for: ${imageFileName}`);
  }

  return assetModule.default;
};

const { limit } = Astro.props as Props;

// Get the project list
let allWorks = (works as RawWork[]).map((work) => ({
  ...work,
  image: resolveProjectImage(work.image),
}));

// If a limit is specified, apply it
if (limit !== undefined) {
  allWorks = allWorks.slice(0, limit);
}
---

<section class="py-8 md:py-8">
  <div class="space-y-8 md:space-y-10">
    <!-- Display all projects full width -->
    {allWorks
      .filter(work => work.isShow !== false)
      .map((work, index) => (
        <WorkCard
          name={work.name}
          description={work.description}
          image={work.image}
          url={work.url}
          tags={work.tags}
          isShow={work.isShow}
          layout="featured"
          index={index}
        />
      ))}
  </div>
</section>

