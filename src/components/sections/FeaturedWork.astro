---
import type { ImageMetadata } from "astro";
import projects from "@/collections/projects.json";
import SectionHeader from "@/components/composites/SectionHeader.astro";
import WorkCard from "@/components/composites/WorkCard.astro";
import Button from "@/components/primitives/Button.astro";

export interface Props {
  title?: string;
  description?: string;
  showAll?: boolean;
  limit?: number;
}

interface Project {
  name: string;
  description?: string;
  image: ImageMetadata;
  url: string;
  tags?: string[];
  isShow?: boolean;
  featured?: boolean;
}

interface RawProject extends Omit<Project, "image"> {
  image: string;
}

const projectImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);

const resolveProjectImage = (imageFileName: string): ImageMetadata => {
  if (!imageFileName) {
    throw new Error("Invalid project image filename.");
  }

  const assetModule = projectImages[`/src/assets/projects/${imageFileName}`];

  if (!assetModule) {
    throw new Error(`Missing project image file for: ${imageFileName}`);
  }

  return assetModule.default;
};

const {
  title = "Key Projects",
  description = "A selection of projects I've worked on, ranging from mobile applications to physical products.",
  showAll = false,
  limit,
} = Astro.props as Props;

const featuredSourceProjects = (projects as RawProject[]).filter((project) => project.featured);

let allProjects = featuredSourceProjects.map((project) => ({
  ...project,
  image: resolveProjectImage(project.image),
}));

if (limit !== undefined) {
  allProjects = allProjects.slice(0, limit);
} else if (!showAll) {
  allProjects = allProjects.slice(0, 6);
}

const featuredProjects = allProjects.slice(0, 3);

const gridProjects = allProjects.slice(3);

const shouldShowViewAll =
  limit !== undefined
    ? limit < featuredSourceProjects.length
    : !showAll && featuredSourceProjects.length > 6;
---

<section class="py-16 md:py-16 md:pb-12">
  <div class="site-container space-y-8 md:space-y-8">
    <SectionHeader title={title} description={description} />

    {
      featuredProjects.length > 0 && (
        <div
          class="space-y-8 md:space-y-10"
          data-aos-delay="750"
          data-aos="fade-up-sm"
          data-aos-duration="1000"
          data-aos-once="true"
        >
          {featuredProjects
            .filter((project) => project.isShow !== false)
            .map((project, index) => (
              <WorkCard
                name={project.name}
                description={project.description}
                image={project.image}
                url={project.url}
                tags={project.tags}
                isShow={project.isShow}
                layout="featured"
                index={index}
              />
            ))}
        </div>
      )
    }

    {
      gridProjects.length > 0 && (
        <div
          class="grid gap-6 md:gap-8 md:grid-cols-2"
          data-aos-delay="150"
          data-aos="fade-up-sm"
          data-aos-duration="1000"
          data-aos-once="true"
        >
          {gridProjects
            .filter((project) => project.isShow !== false)
            .map((project, index) => (
              <WorkCard
                name={project.name}
                description={project.description}
                image={project.image}
                url={project.url}
                tags={project.tags}
                isShow={project.isShow}
                layout="grid"
                index={index}
              />
            ))}
        </div>
      )
    }

    {
      shouldShowViewAll && (
        <div class="flex items-center justify-center pt-8">
          <Button
            url="/projects"
            type="fill"
            className="justify-center w-full sm:w-auto min-w-40 flex items-center gap-2"
          >
            See all projects
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </Button>
        </div>
      )
    }
  </div>
</section>
