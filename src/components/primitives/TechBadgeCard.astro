---
import { Icon } from "astro-icon/components";

export interface Props {
  icon: string;
  label: string;
  class?: string;
}

const { icon, label, class: className = "" } = Astro.props as Props;
---

<div
  class={`p-4 rounded-xl border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 flex flex-col items-center text-center ${className}`.trim()}
>
  <Icon
    name={icon}
    class="w-12 h-12 mb-3 text-neutral-800 dark:text-neutral-200"
    aria-hidden="true"
  />
  <p class="mt-3 mb-3 text-sm font-medium text-neutral-700 dark:text-neutral-200">{label}</p>
</div>