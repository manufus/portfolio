---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  figureClassName?: string;
  pictureClassName?: string;
  imageClassName?: string;
  quality?: number;
  loading?: "eager" | "lazy";
  decoding?: "async" | "auto" | "sync";
}

const {
  src,
  alt,
  caption,
  figureClassName,
  pictureClassName = "picture rounded-2xl overflow-hidden block",
  imageClassName = "w-full h-full object-cover",
  quality = 100,
  loading = "lazy",
  decoding = "async",
} = Astro.props as Props;

const resolvedFigureClassName = figureClassName ?? "mt-8 md:mt-12 mb-8 md:mb-12";
const hasCaptionSlot = Astro.slots.has("caption");
---

<figure
  {...(resolvedFigureClassName !== "" ? { class: resolvedFigureClassName } : {})}
>
  <picture class={pictureClassName}>
    <Image
      src={src}
      alt={alt}
      class={imageClassName}
      loading={loading}
      decoding={decoding}
      quality={quality}
    />
  </picture>
  {
    (caption || hasCaptionSlot) && (
      <figcaption class="text-center text-sm text-neutral-500 mt-3 italic">
        {caption ? caption : <slot name="caption" />}
      </figcaption>
    )
  }
</figure>