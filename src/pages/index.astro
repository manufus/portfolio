---
import HeroCard from "@/components/home/HeroCard.astro";
import AnimatedText from "@/components/ui/AnimatedText.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import FeaturedWork from "../components/sections/FeaturedWork.astro";
import Button from "../components/ui/Button.astro";

const title = "Manuel Portfolio - UX Engineer and Interaction Designer";
const description =
  "UX Engineer portfolio focused on user-centered interaction design, accessibility, and measurable performance outcomes.";
---

<Layout
  title={title}
  description={description}
  keywords={siteConfig.meta.keywords}
  image="/og/home.jpg"
>
  <div
    class="relative site-container z-20 w-full mx-auto mt-16 px-4 md:mt-18 lg:mt-20 xl:px-0"
  >
    <div
      class="relative w-full px-4 flex flex-col items-center justify-between md:flex-row mb-16"
    >
      <div class="relative w-full md:max-w-[420px] md:w-1/2 text-left sm:-mt-8">
        <!-- Title - AnimatedText animation -->
        <h1 class="mb-4">
          <AnimatedText
            content="Hi, I'm Manuel"
            delay={0.1}
            duration={0.5}
            stagger={0.08}
            class="text-5xl text-content-primary leading-tight md:text-4xl lg:text-6xl font-brand"
          />
        </h1>

        <!-- First description - AnimatedText animation -->
        <div class="mb-2">
          <AnimatedText
            content="I'm a UX Engineer & Interaction Designer specialized in Human-Computer Interaction and Design (HCID)."
            delay={0.3}
            duration={0.5}
            stagger={0.015}
            class="text-base text-neutral-700 dark:text-neutral-300"
          />
        </div>

        <!-- Second description - AnimatedText animation -->
        <div class="mb-4">
          <AnimatedText
            content="I combine engineering and design to create human-centered, digital experiences, from interaction research to implementation."
            delay={0.5}
            duration={0.5}
            stagger={0.015}
            class="text-base text-neutral-700 dark:text-neutral-300"
          />
        </div>

        <!-- Buttons - AOS animation -->
        <div
          class="flex flex-col sm:flex-row gap-4 mt-6"
          data-aos="fade-up-sm"
          data-aos-delay="900"
          data-aos-duration="500"
          data-aos-once="true"
        >
          <Button
            url={siteConfig.social.linkedin}
            target="_blank"
            type="fill"
            className="justify-center w-full sm:w-auto min-w-40 flex items-center gap-2"
          >
            LinkedIn
            <svg
              viewBox="0 0 1024 1024"
              width="18"
              height="18"
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M880 112H144c-17.7 0-32 14.3-32 32v736c0 17.7 14.3 32 32 32h736c17.7 0 32-14.3 32-32V144c0-17.7-14.3-32-32-32zM349.3 793.7H237.5V435.9h111.8v357.8zM293.4 387c-35.8 0-64.9-29-64.9-64.8s29.1-64.8 64.9-64.8 64.9 29 64.9 64.8-29.1 64.8-64.9 64.8zM793.7 793.7H681.8V603.2c0-45.4-16.2-76.4-56.9-76.4-31 0-49.5 20.9-57.6 41.1-3 7.2-3.7 17.2-3.7 27.2v198.6H451.9s1.5-322.2 0-357.8h111.8v50.7c14.9-23 41.6-55.8 101.1-55.8 73.8 0 128.9 48.2 128.9 151.8v151.1z"
              ></path></svg
            >
          </Button>

          <!-- <Button
            url={siteConfig.social.github}
            target="_blank"
            type="fill"
            className="justify-center w-full sm:w-auto min-w-40 flex items-center gap-2"
          >
            GitHub
            <svg
              viewBox="0 0 1024 1024"
              width="18"
              height="18"
              fill="currentColor"
              version="1.1"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M511.957333 21.333333C241.024 21.333333 21.333333 240.981333 21.333333 512c0 216.832 140.544 400.725333 335.573334 465.664 24.490667 4.394667 32.256-10.069333 32.256-23.082667 0-11.690667 0.256-44.245333 0-85.205333-136.448 29.610667-164.736-64.64-164.736-64.64-22.314667-56.704-54.4-71.765333-54.4-71.765333-44.586667-30.464 3.285333-29.824 3.285333-29.824 49.194667 3.413333 75.178667 50.517333 75.178667 50.517333 43.776 75.008 114.816 53.333333 142.762666 40.789333 4.522667-31.658667 17.152-53.376 31.189334-65.536-108.970667-12.458667-223.488-54.485333-223.488-242.602666 0-53.546667 19.114667-97.322667 50.517333-131.669334-5.034667-12.330667-21.930667-62.293333 4.778667-129.834666 0 0 41.258667-13.184 134.912 50.346666a469.802667 469.802667 0 0 1 122.88-16.554666c41.642667 0.213333 83.626667 5.632 122.88 16.554666 93.653333-63.488 134.784-50.346667 134.784-50.346666 26.752 67.541333 9.898667 117.504 4.864 129.834666 31.402667 34.346667 50.474667 78.122667 50.474666 131.669334 0 188.586667-114.730667 230.016-224.042666 242.090666 17.578667 15.232 33.578667 44.672 33.578666 90.453334v135.850666c0 13.141333 7.936 27.605333 32.853334 22.869334C862.250667 912.597333 1002.666667 728.746667 1002.666667 512 1002.666667 240.981333 783.018667 21.333333 511.957333 21.333333z"
              ></path>
            </svg>
          </Button> -->
        </div>
      </div>

      <!-- HeroCard - AOS animation -->
      <div
        class="relative justify-end w-full mt-16 md:flex md:pl-10 md:w-1/2 md:mt-0 md:translate-y-4 xl:translate-y-0"
        data-aos="fade-left-sm"
        data-aos-delay="300"
        data-aos-duration="800"
        data-aos-once="true"
      >
        <HeroCard
          imageUrl="/assets/home/manuelhr.jpg"
          title="About me"
          link="/about"
        />
      </div>
    </div>
  </div>

  <section
    class="mt-26 mb-12"
    data-aos="fade-up-sm"
    data-aos-delay="100"
    data-aos-duration="600"
    data-aos-once="true"
    role="main"
  >
    <FeaturedWork
      title="Key Projects ↓"
      description="Bridging the gap between Engineering and Design through user-centered solutions."
      limit={3}
    />
  </section>

</Layout>
