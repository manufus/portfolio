---
import heroPortrait from "@/assets/home/manuelhr.jpg";
import HeroCard from "@/components/composites/HeroCard.astro";
import AnimatedText from "@/components/primitives/AnimatedText.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import FeaturedWork from "../components/sections/FeaturedWork.astro";

const title = "Manuel Portfolio - UX Engineer and Interaction Designer";
const description =
  "UX Engineer portfolio focused on user-centered interaction design, accessibility, and measurable performance outcomes.";
---

<Layout
  title={title}
  description={description}
  keywords={siteConfig.meta.keywords}
  image="/og/home.jpg"
>
  <div
    class="relative site-container z-20 w-full mx-auto mt-16 px-4 md:mt-18 lg:mt-20 xl:px-0"
  >
    <div
      class="relative w-full px-4 flex flex-col items-center gap-2 md:gap-0 md:justify-between md:flex-row mb-2"
    >
      <div class="relative w-full md:max-w-[420px] md:w-1/2 text-left sm:-mt-8">
        <!-- Title - AnimatedText animation -->
        <h1 class="mb-4">
          <AnimatedText
            content="Hi, I'm Manu"
            delay={0.1}
            duration={0.5}
            stagger={0.08}
            class="text-5xl text-content-primary leading-tight md:text-4xl lg:text-6xl font-brand"
          />
        </h1>

        <!-- First description - AnimatedText animation -->
        <div class="mb-2">
          <AnimatedText
            content="I'm a UX Engineer & Interaction Designer specialized in Human-Computer Interaction and Design (HCID). I combine engineering and design to create human-centered, digital experiences, from interaction research to implementation."
            delay={0.3}
            duration={0.5}
            stagger={0.015}
            class="text-base text-neutral-700 dark:text-neutral-300"
          />
        </div>

        
        <!-- Buttons - AOS animation -->
        <div
          class="flex flex-col sm:flex-row gap-4 mt-6"
          data-aos="fade-up-sm"
          data-aos-delay="900"
          data-aos-duration="500"
          data-aos-once="true"
        >
        
        </div>
      </div>

      <!-- HeroCard - AOS animation -->
      <div
        class="relative justify-end w-full mt-16 md:flex md:pl-10 md:w-1/2 md:mt-0 md:translate-y-4 xl:translate-y-0"
        data-aos="fade-left-sm"
        data-aos-delay="300"
        data-aos-duration="800"
        data-aos-once="true"
      >
        <HeroCard
          image={heroPortrait}
          title="About me"
          link="/about"
        />
      </div>
    </div>

    <!-- Scroll Down Arrow - Mobile Only -->
    <div
      class="block md:hidden w-full flex justify-center pt-8"
      data-aos="fade-up-sm"
      data-aos-delay="1200"
      data-aos-duration="600"
      data-aos-once="true"
    >
      <svg
        class="w-6 h-6 text-neutral-800 dark:text-neutral-200 animate-bounce"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"
        />
      </svg>
    </div>
  </div>

  <section
    class="mt-26 mb-12"
    data-aos="fade-up-sm"
    data-aos-delay="100"
    data-aos-duration="600"
    data-aos-once="true"
    role="main"
  >
    <FeaturedWork
      title="Key Projects ↓"
      description="Discover how I combine Engineering and Design to create user-centered solutions."
      limit={3}
    />
  </section>

</Layout>
