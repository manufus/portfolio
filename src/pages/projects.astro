---
import { Icon } from "astro-icon/components"; // Iconos para la nueva sección
import PageHeader from "@/components/elements/PageHeader.astro";
import WorksSection from "@/components/sections/WorksSection.astro";
import Button from "@/components/ui/Button.astro"; // Asegúrate de importar el Botón
import PageLayout from "@/layouts/PageLayout.astro";

const title = "Projects | Manuel Hortelano - UX Engineer";
const description =
  "UX engineering case studies across HCID, industrial CMMS redesign, VR training, and prototyping with measurable outcomes and method-driven execution.";
---

<PageLayout title={title} description={description}>
  <section class="site-container m-auto mb-12 sm:mb-20">
    <PageHeader
      title="Projects"
    />
    <p class="mt-3 text-sm leading-6 sm:mt-4 sm:leading-7 sm:text-base text-content-secondary text-center max-w-2xl mx-auto">
      A selection of key projects, presented concisely. I am constantly updating this space with my most recent work, so be sure to check back often!
    </p>

    <WorksSection />

    <div class="mt-16 sm:mt-24">
      <div
        class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 mb-12 flex justify-center"
      >
        <div class="bg-white dark:bg-neutral-950 px-4 -mb-3 text-neutral-400">
          <Icon name="lucide:archive" width={20} height={20} />
        </div>
      </div>

      <div class="text-center max-w-2xl mx-auto px-4" data-aos="fade-up">
        <h3
          class="text-xl font-semibold text-neutral-800 dark:text-neutral-200 mb-3"
        >
          Looking for older projects?
        </h3>
        <p class="text-neutral-600 dark:text-neutral-400 mb-8 leading-relaxed">
          I'm currently in the process of migrating my full archive to this new
          website. In the meantime, you can access my previous portfolios via
          the links below.
          <span class="text-sm italic block mt-1 opacity-75"
            >(Note: These documents reflect my work up to 2023-2024).</span
          >
        </p>

        <div
          class="flex flex-col sm:flex-row gap-4 justify-center items-center"
        >
          <Button
            url="https://drive.google.com/file/d/1VNjQCTQrNv-n9gqY9hRAxCf0YhNDfev0/view?usp=drive_link"
            target="_blank"
            type="fill"
            className="whitespace-nowrap"
          >
            UI Portfolio 2024 <Icon name="lucide:external-link" width={16} height={16} class="ml-2" />
          </Button>

          <Button
            url="https://drive.google.com/file/d/1w0Y9e6PUbcU3xHPTh_uodZ9wRLT7zktX/view?usp=drive_link"
            target="_blank"
            type="fill"
            className="whitespace-nowrap"
          >
            Engineering Portfolio 2023<Icon name="lucide:external-link" width={16} height={16} class="ml-2" />
          </Button>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
