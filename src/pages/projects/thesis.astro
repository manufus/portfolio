---
import type { ImageMetadata } from "astro";
import CaptionImage from "@/components/composites/CaptionImage.astro";
import MetricsGrid from "@/components/composites/MetricsGrid.astro";
import ActionBar from "@/components/features/ActionBar.astro";
import Layout from "@/layouts/Layout.astro";
import ProjectCaseShell from "@/components/composites/ProjectCaseShell.astro";

const allImagesModules = import.meta.glob("../../assets/projects/thesis/*.{jpg,png,webp}", {
  eager: true,
});
const allImages = Object.values(allImagesModules) as Array<{
  default: ImageMetadata;
}>;
---

<Layout
  title="HCID Thesis: CMMS UX Redesign | Manuel Hortelano - UX Engineer"
  description="HCID thesis for Sisteplant: CMMS redesign with interviews, Dovetail coding, and usability tests that reached SUS 72 and 100% critical task completion."
  keywords="Design Systems, HCID Master's Thesis, UX Research, Industrial B2B UX, Usability Optimization"
  image="/og/projects-thesis.jpg"
>
  <ProjectCaseShell title="HCID Industrial Thesis: Design Systems for Usability Optimization" tags={["UX Research", "Design Systems", "UCD"]}>
        <div class="mb-12">
          <h3>Overview: Digital Transformation in Maintenance</h3>
          <p>
            This project represents my <strong>30 ECTS Master's Thesis</strong> for
            the HCID (Human-Computer Interaction and Design) Double Degree program.
            Collaborating with an industrial partner, <strong>Sisteplant</strong
            >, I executed the end-to-end redesign of the mobile module for their
            Computerized Maintenance Management System (CMMS). The goal was to
            improve the User Experience (UX) by providing an user-centred
            digital tool that empowers field technicians in complex industrial
            environments.
          </p>

          {
            allImages[0] && (
              <CaptionImage
                src={allImages[0].default}
                alt="Thesis process overview"
                caption="Thesis process overview"
              />
            )
          }
        </div>

        <div class="mb-12">
          <h3>The Challenge: Information Obesity</h3>
          <p>
            Maintenance operators work in high-pressure environments constantly
            interacting physically with different elements. The previous
            desktop-centric system resulted in:
          </p>
          <ul class="list-disc space-y-2 mt-4 text-base">
            <li>
              <strong>High Cognitive Load:</strong> Small screens cluttered with irrelevant
              administrative data.
            </li>
            <li>
              <strong>Inefficiency:</strong> Critical tasks buried under multiple
              navigation layers.
            </li>
            <li>
              <strong>Low Adoption:</strong> Steep learning curve for non-digital
              native technicians.
            </li>
          </ul>
          <p class="mt-4">
            The challenge was to transform complex technical data into a <strong
              >Task-Oriented UI</strong
            > that presents exactly what the technician needs, when they need it.
          </p>
        </div>

        <div class="mb-12">
          <h3>Methodology: Rigorous User-Centered Design</h3>
          <p>
            I applied a structured UCD process to ensure the solution was
            grounded in real user needs:
          </p>
          <ul class="list-disc pl-5 space-y-2 mt-4 text-base">
            <li>
              <strong>Discovery:</strong> Conducted semi-structured interviews with
              stakeholders and end-users to understand the "Field Technician" persona.
            </li>
            <li>
              <strong>Analysis:</strong> Used <em>Dovetail</em> for inductive/deductive
              coding to identify critical pain points in current workflows.
            </li>
            <li>
              <strong>Definition:</strong> Extracted the most critical tasks and prioritized
              them for the redesign.
            </li>
          </ul>

          {
            allImages[1] && (
              <CaptionImage
                src={allImages[1].default}
                alt="Coding of the semi-structured interviews in Dovetail"
                caption="Coding of the semi-structured interviews in Dovetail"
              />
            )
          }
        </div>

        <div class="mb-12">
          <h3>Solution: Adapting Carbon Design System</h3>
          <p>
            To ensure scalability and consistency across the system, I adapted
            the <strong>Carbon Native Mobile</strong> design system focusing on three
            pillars:
          </p>
          <ul class="list-disc pl-5 space-y-2 mt-4 text-base">
            <li>
              <strong>Progressive Disclosure:</strong> Utilizing accordion patterns
              to hide secondary information until needed.
            </li>
            <li>
              <strong>Actionability:</strong> Floating Action Buttons (FAB) for primary
              tasks like "Create Request" or "Report Failure".
            </li>
            <li>
              <strong>Consistency:</strong> Providing with the same behaviour and
              unifying interactions to reduce mental effort.
            </li>
          </ul>
        </div>

        {
          allImages[2] && (
            <CaptionImage
              src={allImages[2].default}
              alt="High Fidelity prototype in Figma"
              caption="High Fidelity prototype in Figma"
            />
          )
        }

        <div class="mb-12">
          <h3>Validation & Impact</h3>
          <p>
            The prototype was validated through on-site <strong
              >usability testing</strong
            > with maintenance professionals, resulting in:
          </p>
          <MetricsGrid
            className="mt-6"
            items={[
              {
                value: "72",
                label: "SUS Score",
                description: "",
                descriptionHtml:
                  'Rated as "Good Usability" (Grade B), ranking in the <strong>75th percentile</strong> of evaluated systems.',
              },
              {
                value: "100%",
                label: "Completion Rate",
                description:
                  'All participants successfully completed the critical "Work Order Execution" task without critical errors.',
              },
            ]}
          />
        </div>

        {
          allImages[3] && (
            <CaptionImage
              src={allImages[3].default}
              alt="Interpretation of the SUS Score"
            >
              <span slot="caption">
                Interpretation of the SUS Score. Image Source:
                <a href="https://www.uxables.com/investigacion-ux/medir-con-el-sistema-de-escala-de-usabilidad-sus/">
                  UXABLES
                </a>
              </span>
            </CaptionImage>
          )
        }
      </ProjectCaseShell>
</Layout>

<ActionBar
  tags={[]}
  visitLabel="Read Thesis"
  url="https://urn.fi/URN:NBN:fi:aalto-202510208321"
  figma="https://www.figma.com/proto/ZAtd9QoyQshJb1s22aeh7u/Prisma-Mobile?node-id=298-15194&viewport=154%2C321%2C0.1&t=u5ZcQIFabVyS1XYl-0&scaling=min-zoom&content-scaling=fixed&starting-point-node-id=298%3A15194"
/>
