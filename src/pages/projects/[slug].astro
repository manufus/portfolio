---
import type { GetStaticPaths } from 'astro'
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import ProjectCaseShell from '@/components/composites/ProjectCaseShell.astro'
import ActionBar from '@/components/features/ActionBar.astro'
import { siteConfig } from '@/config/site'
import Layout from '@/layouts/Layout.astro'

interface Props {
    entry: CollectionEntry<'projects'>
}

export const getStaticPaths = (async () => {
    const entries = await getCollection('projects')

    return entries.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }))
}) satisfies GetStaticPaths

const { entry } = Astro.props as Props
const { Content } = await render(entry)
---

<Layout
    title={`${entry.data.title} | ${siteConfig.title} - ${siteConfig.role}`}
    description={entry.data.description}
    keywords={entry.data.keywords}
    image={entry.data.image.src}
>
    <ProjectCaseShell title={entry.data.title} tags={entry.data.tags}>
        <Content />
    </ProjectCaseShell>
</Layout>

{
    entry.data.primaryAction ? (
        <ActionBar
            primaryAction={entry.data.primaryAction}
            secondaryActions={entry.data.secondaryActions}
        />
    ) : (
        <ActionBar secondaryActions={entry.data.secondaryActions} />
    )
}
